#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT = development
# production | testing | development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'http://localhost:8080/'
# app.baseURL = 'https://example.com/'

#--------------------------------------------------------------------
# ENCRYPTION KEY
# Generate with: php spark key:generate
#--------------------------------------------------------------------
encryption.key =

#--------------------------------------------------------------------
# DATABASE (SQLite — path relative to WRITEPATH)
# Default: writable/database/cekirdek.db
# Override if needed:
# database.default.database = writable/database/cekirdek.db
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# LOGGING
# 0=off, 4=info, 9=all
#--------------------------------------------------------------------
# logger.threshold = 4

#--------------------------------------------------------------------
# ESTATE MODULE — modeiland
#--------------------------------------------------------------------

# Feature flags
BILLING_ENABLED = false

# AI Provider: openai | anthropic
AI_PROVIDER = openai
AI_API_KEY  =
AI_MODEL    = gpt-4o-mini

# Pricing (cents) — overrides Config/Estate.php defaults
# SEEKER_PRICE_CENTS = 500          # 5 €/month
# OWNER_EXTRA_LISTING_CENTS = 2000  # 20 € one-off

#--------------------------------------------------------------------
# STRIPE (Faz 3 — only required when BILLING_ENABLED = true)
# Get keys: https://dashboard.stripe.com/apikeys
# Webhook secret: https://dashboard.stripe.com/webhooks
# → Add endpoint URL: https://yourdomain.de/webhooks/stripe
# → Events to listen: checkout.session.completed,
#   customer.subscription.updated, customer.subscription.deleted,
#   invoice.payment_succeeded
#--------------------------------------------------------------------
STRIPE_SECRET_KEY      =            # sk_live_... or sk_test_...
STRIPE_PUBLISHABLE_KEY =            # pk_live_... or pk_test_...
STRIPE_WEBHOOK_SECRET  =            # whsec_...
STRIPE_SEEKER_PRICE_ID =            # price_... (recurring 5 €/month — create in Stripe dashboard)

#--------------------------------------------------------------------
# CLOUDFLARE IMAGES (Faz 4 — optional, falls back to local paths)
# Requires: Cloudflare Images add-on on your account.
# Cron spark estate:upload-images uploads approved photos automatically.
#--------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID        =      # 32-char hex from CF dashboard
CLOUDFLARE_IMAGES_TOKEN      =      # API token with Images:Edit permission
CLOUDFLARE_IMAGES_DELIVERY_URL =    # e.g. https://imagedelivery.net/<hash>

#--------------------------------------------------------------------
# EMAIL / SMTP (transactional — Resend / Brevo / Postmark / Hostinger)
# Set in app/Config/Email.php or override here via CI4 env syntax:
#--------------------------------------------------------------------
# email.SMTPHost     = smtp.resend.com
# email.SMTPUser     = resend
# email.SMTPPass     =
# email.SMTPPort     = 587
# email.SMTPCrypto   = tls
# email.fromEmail    = noreply@modeiland.de
# email.fromName     = modeiland
#
# SPF/DKIM/DMARC: configure DNS records for your sending domain.
# See: https://resend.com/docs/dashboard/domains/introduction
